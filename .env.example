# =============================================
# CreatoRain Social Scheduler Configuration
# =============================================

# --- Core URLs ---
MAIN_URL=http://localhost:4007
FRONTEND_URL=http://localhost:4007
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://localhost:3000

# --- Auth ---
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# --- Database (separate DB on same PostgreSQL server as app-backend) ---
DATABASE_URL=postgresql://postiz:postiz_password@postiz-postgres:5432/social_scheduler

# --- Redis ---
REDIS_URL=redis://postiz-redis:6379

# --- Temporal Workflow Engine ---
TEMPORAL_ADDRESS=temporal:7233

# --- Storage: Reuse CreatoRain AWS S3 ---
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=buyfishingrod-assets
AWS_S3_PREFIX=social/
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_URL=https://cdn.buyfishingrod.com/social

# --- Email: AWS SES ---
EMAIL_PROVIDER=ses
EMAIL_FROM_ADDRESS=noreply@creatorain.com
EMAIL_FROM_NAME=CreatoRain
AWS_SES_REGION=us-east-1

# --- AI (reuse existing OpenAI key) ---
OPENAI_API_KEY=

# --- Social Media OAuth (configure one at a time) ---
# Facebook + Instagram (same app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Disable payment (internal tool) ---
IS_GENERAL=true
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- Developer Settings ---
NX_ADD_PLUGINS=false
DISABLE_REGISTRATION=false

# --- Monitoring (optional) ---
# SENTRY_DSN=
